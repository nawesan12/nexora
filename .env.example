# ===========================================
# Nexora ERP - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgres://nexora:nexora@localhost:5432/nexora?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_USER=nexora
DB_PASSWORD=nexora
DB_NAME=nexora

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- API Server ----
API_PORT=8080
API_HOST=0.0.0.0
API_ENV=development

# ---- JWT ----
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=168h

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Next.js Web ----
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_APP_NAME=Nexora
NEXT_PUBLIC_APP_URL=http://localhost:3000
